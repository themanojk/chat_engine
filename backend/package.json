{
  "name": "@littra/chat-engine-backend",
  "version": "0.1.0",
  "description": "Multi-tenant chat engine backend package",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:server": "tsx demo/server.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:socket": "TEST_SOCKET_ENABLED=true jest --runInBand src/socket/tests/chat-socket-server.spec.ts",
    "test:postgres": "TEST_POSTGRES_ENABLED=true jest --runInBand src/adapters/tests/postgres.adapter.spec.ts",
    "test:mongo": "TEST_MONGO_ENABLED=true jest --runInBand src/adapters/tests/mongo.adapter.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.24.2",
    "knex": "^3.1.0",
    "mongodb": "^6.18.0",
    "pg": "^8.12.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2"
  }
}
