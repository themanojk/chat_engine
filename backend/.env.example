PORT=4000
DEMO_TENANT_ID=tenant-demo
DEMO_USERS=user-a,user-b,user-c

# Supported values: in-memory | postgres | mongo
CHAT_STORAGE_TYPE=in-memory
DEMO_JWT_SECRET=dev-chat-engine-secret

# Postgres settings (used when CHAT_STORAGE_TYPE=postgres)
DATABASE_URL=postgres://localhost:5432/chat_engine
TEST_POSTGRES_URL=postgres://localhost:5432/chat_engine_test

# Mongo settings (used when CHAT_STORAGE_TYPE=mongo)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=chat_engine
TEST_MONGO_URI=mongodb://localhost:27017
TEST_MONGO_DB=chat_engine_test
